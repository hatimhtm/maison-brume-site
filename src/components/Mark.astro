---
// The Maison Brume mark. Cochin (the IG avatar face) is Apple-only and
// not licensable for the web, so the site mark is set in Fraunces — the
// same editorial voice as the rest of the type. Deliberate, not a fallback.
interface Props {
  variant?: "monogram" | "word";
  class?: string;
}
const { variant = "monogram", class: cls = "" } = Astro.props;
---

{
  variant === "monogram" ? (
    <span class={`mb-mark ${cls}`} aria-hidden="true">
      MB
    </span>
  ) : (
    <span class={`mb-word ${cls}`}>Maison&nbsp;Brume</span>
  )
}

<style>
  .mb-mark {
    font-family: var(--font-display);
    font-weight: 420;
    font-size: 1.4rem;
    letter-spacing: 0.04em;
    font-variation-settings: "opsz" 120, "SOFT" 40;
    color: var(--color-ink);
    line-height: 1;
  }
  .mb-word {
    font-family: var(--font-display);
    font-weight: 400;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-size: 0.95rem;
    font-variation-settings: "opsz" 36;
    color: var(--color-ink);
  }
</style>
