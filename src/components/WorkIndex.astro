---
import { content, type Locale, WORK_SLUGS, waLink } from "../lib/content";
import { path, asset } from "../lib/paths";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = content[locale];
const wa = waLink(locale);
---

<section class="wi">
  <div class="wrap">
    <header class="wi__head reveal">
      <p class="eyebrow">{t.work.eyebrow}</p>
      <h1 class="wi__title">{t.work.title}</h1>
      <p class="lead measure wi__framing">{t.work.framing}</p>
    </header>

    <div class="wi__grid">
      {
        WORK_SLUGS.map((slug, i) => {
          const it = t.work.items[slug];
          return (
            <a class="card reveal" href={path(`/work/${slug}`, locale)}>
              <div class="card__frame reveal--img">
                <span class="card__no">{String(i + 1).padStart(2, "0")}</span>
                <img
                  class="card__img"
                  src={asset(`work/${slug}.jpg`)}
                  alt={`${it.name} — ${it.kind}`}
                  width="1600"
                  height="1000"
                  loading={i < 2 ? "eager" : "lazy"}
                  decoding="async"
                />
              </div>
              <div class="card__meta">
                <span class="card__name">{it.name}</span>
                <span class="card__kind">{it.kind}</span>
                <span class="card__line">{it.line}</span>
                <span class="card__view">{t.work.view} <span aria-hidden="true">→</span></span>
              </div>
            </a>
          );
        })
      }
    </div>

    <div class="wi__close reveal">
      <p class="wi__close-t">{t.work.closing}</p>
      <a class="btn" href={wa} target="_blank" rel="noopener">{t.work.closingCta}</a>
    </div>
  </div>
</section>

<style>
  .wi { padding-block: clamp(7rem, 12vw, 11rem) var(--section-y); }
  .wi__head { margin-bottom: clamp(3rem, 7vw, 5.5rem); max-width: 30ch; }
  .wi__title { margin-top: 1.25rem; }
  .wi__framing { margin-top: 1.5rem; color: var(--color-ink-soft); }

  .wi__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(2rem, 5vw, 4.5rem) clamp(1.5rem, 4vw, 3rem);
  }
  .wi__grid .card:first-child,
  .wi__grid .card:nth-child(4) {
    grid-column: 1 / -1;
  }

  .card { display: block; }
  .card__frame {
    position: relative;
    overflow: hidden;
    background: var(--color-paper);
    border: 1px solid var(--color-fog);
    aspect-ratio: 16 / 10;
  }
  .card__no {
    position: absolute;
    top: 1rem;
    left: 1.1rem;
    z-index: 2;
    font-family: var(--font-display);
    font-size: 0.95rem;
    color: var(--color-bone);
    mix-blend-mode: difference;
  }
  .card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    filter: saturate(0.96);
    transform: scale(1.001);
    transition: transform 1.1s var(--ease), filter 0.9s var(--ease);
  }
  .card:hover .card__img {
    transform: scale(1.035);
    filter: saturate(1.05);
  }
  .card__frame::after {
    content: "";
    position: absolute;
    inset: 0;
    box-shadow: inset 0 0 0 1px rgba(28, 27, 25, 0.06);
    pointer-events: none;
  }

  .card__meta {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: baseline;
    column-gap: 1.5rem;
    padding-top: clamp(1.1rem, 2.5vw, 1.6rem);
  }
  .card__name {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    line-height: 1.1;
  }
  .card__view {
    font-size: 0.76rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-stone);
    white-space: nowrap;
  }
  .card:hover .card__view { color: var(--color-ink); }
  .card__kind {
    grid-column: 1 / -1;
    margin-top: 0.55rem;
    font-size: 0.74rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-stone);
  }
  .card__line {
    grid-column: 1 / -1;
    margin-top: 0.7rem;
    max-width: 46ch;
    color: var(--color-ink-soft);
  }

  .wi__close {
    margin-top: clamp(4rem, 9vw, 7rem);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.25rem 2rem;
  }
  .wi__close-t {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-variation-settings: "opsz" 48, "SOFT" 50;
  }

  @media (max-width: 46rem) {
    .wi__grid { grid-template-columns: 1fr; }
    .wi__grid .card:first-child,
    .wi__grid .card:nth-child(4) { grid-column: auto; }
  }
</style>
