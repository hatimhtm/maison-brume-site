---
import { content, type Locale, waLink } from "../lib/content";
import Ornament from "./Ornament.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = content[locale];
const wa = waLink(locale);
---

<section class="sv">
  <div class="wrap">
    <header class="sv__head reveal">
      <p class="eyebrow">{t.services.eyebrow}</p>
      <h1 class="sv__title">{t.services.title}</h1>
      <p class="lead measure sv__intro">{t.services.intro}</p>
    </header>

    <ol class="sv__list">
      {
        t.services.items.map((s, i) => (
          <li class="sv__row reveal">
            <span class="sv__no">
              <Ornament class="sv__orn" />
              {String(i + 1).padStart(2, "0")}
            </span>
            <div class="sv__body">
              <h2 class="sv__name">{s.name}</h2>
              <p class="sv__out">{s.outcome}</p>
            </div>
          </li>
        ))
      }
    </ol>

    <div class="sv__cta reveal btn-row">
      <a class="btn" href={wa} target="_blank" rel="noopener">{t.services.cta}</a>
      <span class="sv__cta-note">{t.contact.direct}</span>
    </div>
  </div>
</section>

<style>
  .sv { padding-block: clamp(7rem, 12vw, 11rem) var(--section-y); }
  .sv__head { max-width: 30ch; margin-bottom: clamp(3rem, 7vw, 5.5rem); }
  .sv__title { margin-top: 1.25rem; }
  .sv__intro { margin-top: 1.75rem; color: var(--color-ink-soft); }

  .sv__list {
    list-style: none;
    padding: 0;
    border-top: 1px solid var(--color-fog);
  }
  .sv__row {
    display: grid;
    grid-template-columns: minmax(0, 9rem) 1fr;
    gap: clamp(1rem, 5vw, 4rem);
    padding-block: clamp(2.25rem, 5vw, 3.5rem);
    border-bottom: 1px solid var(--color-fog);
    transition: padding-left var(--dur) var(--ease);
  }
  @media (hover: hover) {
    .sv__row:hover { padding-left: 0.5rem; }
  }
  .sv__no {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--color-stone);
    padding-top: 0.4rem;
  }
  .sv__name {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    line-height: 1.08;
  }
  .sv__out {
    margin-top: 0.9rem;
    max-width: 48ch;
    color: var(--color-ink-soft);
    font-size: var(--text-lead);
    line-height: 1.5;
  }
  .sv__cta {
    margin-top: clamp(3.5rem, 8vw, 6rem);
    gap: 1.25rem 2rem;
  }
  .sv__cta-note {
    max-width: 30ch;
    color: var(--color-stone);
    font-size: 0.9rem;
  }
  @media (max-width: 40rem) {
    .sv__row { grid-template-columns: 1fr; gap: 0.6rem; }
    .sv__no { padding-top: 0; }
  }
</style>
