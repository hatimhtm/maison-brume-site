---
import { content, type Locale, waLink } from "../lib/content";
import { path } from "../lib/paths";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = content[locale];
const wa = waLink(locale);
---

<section class="st">
  <div class="wrap">
    <header class="st__head reveal">
      <p class="eyebrow">{t.studio.eyebrow}</p>
      <h1 class="st__title">{t.studio.title}</h1>
    </header>

    <blockquote class="st__belief reveal">
      <p>{t.studio.belief}</p>
    </blockquote>

    <dl class="st__points">
      {
        t.studio.points.map((p) => (
          <div class="st__row reveal">
            <dt>{p.k}</dt>
            <dd>{p.v}</dd>
          </div>
        ))
      }
    </dl>

    <div class="st__cta reveal btn-row">
      <a class="btn" href={wa} target="_blank" rel="noopener">{t.hero.b}</a>
      <a class="link" href={path("/contact", locale)}>{t.contact.title}</a>
    </div>
  </div>
</section>

<style>
  .st { padding-block: clamp(8rem, 14vw, 13rem) var(--section-y); }
  .st__head { max-width: 24ch; }
  .st__title { margin-top: 1.25rem; }
  .st__belief {
    margin-block: clamp(3.5rem, 9vw, 7rem);
    border: 0;
    border-left: 1px solid var(--color-ink);
    padding-left: clamp(1.25rem, 4vw, 2.5rem);
    max-width: 30rem;
  }
  .st__belief p {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    line-height: 1.28;
    font-variation-settings: "opsz" 48, "SOFT" 50;
  }
  .st__points {
    border-top: 1px solid var(--color-fog);
  }
  .st__row {
    display: grid;
    grid-template-columns: minmax(0, 10rem) 1fr;
    gap: clamp(1rem, 5vw, 4rem);
    padding-block: clamp(1.75rem, 3.5vw, 2.75rem);
    border-bottom: 1px solid var(--color-fog);
  }
  .st__row dt {
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-stone);
    padding-top: 0.2rem;
  }
  .st__row dd {
    margin: 0;
    max-width: 42ch;
    color: var(--color-ink-soft);
    font-size: var(--text-lead);
    line-height: 1.5;
  }
  .st__cta { margin-top: clamp(3rem, 7vw, 5.5rem); }
  @media (max-width: 40rem) {
    .st__row { grid-template-columns: 1fr; gap: 0.5rem; }
  }
</style>
