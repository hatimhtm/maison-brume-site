---
// Signature moment: a slow WebGL mist behind the hero — the studio's name,
// made literal. Raw WebGL (no dependency, ~1.5kB), lazy-initialised after
// load, skipped on reduced-motion or no-WebGL. Zero first-paint cost; the
// page is fully usable (bone background) if it never starts.
---

<canvas class="brume" aria-hidden="true"></canvas>

<style>
  .brume {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    opacity: 0;
    transition: opacity 2s ease;
    pointer-events: none;
  }
  .brume[data-on] { opacity: 1; }
</style>

<script>
  const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
  const canvas = document.querySelector<HTMLCanvasElement>(".brume");
  if (canvas && !reduce) {
    const start = () => {
      const gl = canvas.getContext("webgl", {
        antialias: false,
        alpha: true,
        premultipliedAlpha: false,
      });
      if (!gl) return; // graceful: bone background stays

      const vert = `attribute vec2 p;void main(){gl_Position=vec4(p,0.,1.);}`;
      const frag = `
        precision mediump float;
        uniform vec2 r; uniform float t;
        float h(vec2 p){return fract(sin(dot(p,vec2(127.1,311.7)))*43758.5453);}
        float n(vec2 p){vec2 i=floor(p),f=fract(p);f=f*f*(3.-2.*f);
          return mix(mix(h(i),h(i+vec2(1,0)),f.x),mix(h(i+vec2(0,1)),h(i+vec2(1,1)),f.x),f.y);}
        float fbm(vec2 p){float v=0.,a=.5;for(int i=0;i<5;i++){v+=a*n(p);p*=2.03;a*=.5;}return v;}
        void main(){
          vec2 uv=gl_FragCoord.xy/r.xy; uv.x*=r.x/r.y;
          float tt=t*0.028;
          vec2 q=vec2(fbm(uv*1.7+tt),fbm(uv*1.7-tt+5.2));
          float f=fbm(uv*2.3+q*1.8+vec2(tt*0.7,-tt*0.5));
          vec3 lo=vec3(0.957,0.941,0.910); // paper
          vec3 hi=vec3(0.776,0.748,0.700); // deeper fog — more visible
          vec3 col=mix(lo,hi,smoothstep(0.18,0.92,f));
          float vig=smoothstep(1.35,0.15,length(uv-vec2(0.86,0.5)));
          col=mix(lo,col,0.7+0.3*vig);
          gl_FragColor=vec4(col,1.0);
        }`;

      const sh = (type: number, src: string) => {
        const s = gl.createShader(type)!;
        gl.shaderSource(s, src);
        gl.compileShader(s);
        return s;
      };
      const prog = gl.createProgram()!;
      gl.attachShader(prog, sh(gl.VERTEX_SHADER, vert));
      gl.attachShader(prog, sh(gl.FRAGMENT_SHADER, frag));
      gl.linkProgram(prog);
      gl.useProgram(prog);

      const buf = gl.createBuffer();
      gl.bindBuffer(gl.ARRAY_BUFFER, buf);
      gl.bufferData(
        gl.ARRAY_BUFFER,
        new Float32Array([-1, -1, 3, -1, -1, 3]),
        gl.STATIC_DRAW,
      );
      const loc = gl.getAttribLocation(prog, "p");
      gl.enableVertexAttribArray(loc);
      gl.vertexAttribPointer(loc, 2, gl.FLOAT, false, 0, 0);
      const uR = gl.getUniformLocation(prog, "r");
      const uT = gl.getUniformLocation(prog, "t");

      const dpr = Math.min(devicePixelRatio || 1, 1.5);
      const resize = () => {
        const w = canvas.clientWidth * dpr;
        const h = canvas.clientHeight * dpr;
        canvas.width = w;
        canvas.height = h;
        gl.viewport(0, 0, w, h);
        gl.uniform2f(uR, w, h);
      };
      resize();
      addEventListener("resize", resize, { passive: true });

      canvas.setAttribute("data-on", "");
      let raf = 0;
      let running = true;
      const t0 = performance.now();
      const loop = () => {
        if (!running) return;
        gl.uniform1f(uT, (performance.now() - t0) / 1000);
        gl.drawArrays(gl.TRIANGLES, 0, 3);
        raf = requestAnimationFrame(loop);
      };
      loop();

      // Pause off-screen / hidden — battery + GPU courtesy.
      document.addEventListener("visibilitychange", () => {
        if (document.hidden) {
          running = false;
          cancelAnimationFrame(raf);
        } else if (!running) {
          running = true;
          loop();
        }
      });
      const io = new IntersectionObserver((e) => {
        const vis = e[0].isIntersecting;
        if (vis && !running) {
          running = true;
          loop();
        } else if (!vis && running) {
          running = false;
          cancelAnimationFrame(raf);
        }
      });
      io.observe(canvas);
    };

    if ("requestIdleCallback" in window)
      (window as any).requestIdleCallback(start, { timeout: 2500 });
    else addEventListener("load", () => setTimeout(start, 400));
  }
</script>
