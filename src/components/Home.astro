---
import { content, type Locale, WORK_SLUGS, waLink } from "../lib/content";
import { path, asset } from "../lib/paths";
import Ornament from "./Ornament.astro";
import BrumeFog from "./BrumeFog.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = content[locale];
const wa = waLink(locale);
---

<!-- HERO ─ editorial, left-anchored, no centred-stock layout -->
<section class="hero">
  <BrumeFog />
  <div class="wrap hero__content">
    <p class="hero__eyebrow eyebrow reveal">
      <Ornament spin class="hero__orn" />
      {t.hero.eyebrow}
    </p>
    <h1 class="hero__title reveal">{t.hero.title}</h1>
    <div class="hero__base reveal">
      <p class="lead measure">{t.hero.lead}</p>
      <div class="hero__meta">
        <span class="hero__place">{t.hero.place}</span>
        <div class="hero__cta btn-row">
          <a class="btn" href={wa} target="_blank" rel="noopener">{t.hero.b}</a>
          <a class="btn btn--ghost" href={path("/work", locale)}>{t.hero.a}</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- MANIFESTO ─ the point of view -->
<section class="band">
  <div class="wrap band__grid">
    <p class="eyebrow reveal">{t.manifesto.eyebrow}</p>
    <div class="reveal">
      <h2 class="band__title">{t.manifesto.title}</h2>
      <p class="lead measure band__body">{t.manifesto.body}</p>
    </div>
  </div>
</section>

<!-- SELECTED WORK -->
<section class="work">
  <div class="wrap">
    <div class="work__head reveal">
      <p class="eyebrow">{t.work.eyebrow}</p>
      <h2 class="work__title">{t.work.title}</h2>
    </div>
    <ul class="work__list">
      {
        WORK_SLUGS.map((slug, i) => {
          const it = t.work.items[slug];
          return (
            <li class="work__item reveal">
              <a class="work__link" href={path(`/work/${slug}`, locale)}>
                <span class="work__thumb reveal--img">
                  <img
                    src={asset(`work/${slug}.jpg`)}
                    alt={`${it.name} — ${it.kind}`}
                    width="1600"
                    height="1000"
                    loading={i < 2 ? "eager" : "lazy"}
                    decoding="async"
                  />
                </span>
                <span class="work__body">
                  <span class="work__no">{String(i + 1).padStart(2, "0")}</span>
                  <span class="work__name">{it.name}</span>
                  <span class="work__kind">{it.kind}</span>
                  <span class="work__line">{it.line}</span>
                  <span class="work__view" aria-hidden="true">{t.work.view} →</span>
                </span>
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</section>

<!-- WHAT I BUILD (services teaser) -->
<section class="svc">
  <div class="wrap">
    <div class="svc__head reveal">
      <p class="eyebrow">{t.services.teaser}</p>
      <h2 class="svc__title">{t.services.title}</h2>
    </div>
    <ul class="svc__list">
      {
        t.services.items.map((s) => (
          <li class="svc__i reveal">
            <span class="svc__n">{s.name}</span>
            <span class="svc__o">{s.outcome}</span>
          </li>
        ))
      }
    </ul>
    <a class="link svc__more reveal" href={path("/services", locale)}>
      {t.services.teaserMore} →
    </a>
  </div>
</section>

<!-- HOW IT BEGINS -->
<section class="band band--alt">
  <div class="wrap band__grid">
    <p class="eyebrow reveal">{t.begins.eyebrow}</p>
    <div class="reveal">
      <h2 class="band__title">{t.begins.title}</h2>
      <p class="lead measure band__body">{t.begins.body}</p>
      <div class="band__more btn-row">
        <a class="btn" href={wa} target="_blank" rel="noopener">{t.hero.b}</a>
        <a class="link" href={path("/contact", locale)}>{t.nav.contact}</a>
      </div>
    </div>
  </div>
</section>

<!-- HOW IT WORKS (process) -->
<section class="proc">
  <div class="wrap">
    <div class="proc__head reveal">
      <p class="eyebrow">{t.process.eyebrow}</p>
      <h2 class="proc__title">{t.process.title}</h2>
    </div>
    <ol class="proc__list">
      {
        t.process.steps.map((st) => (
          <li class="proc__s reveal">
            <span class="proc__k">{st.k}</span>
            <div class="proc__b">
              <h3 class="proc__t">{st.t}</h3>
              <p class="proc__d">{st.d}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<!-- CLOSE -->
<section class="close">
  <div class="wrap">
    <p class="eyebrow reveal">{t.close.eyebrow}</p>
    <h2 class="close__t reveal">{t.close.title}</h2>
    <p class="lead measure close__b reveal">{t.close.body}</p>
    <div class="close__cta btn-row reveal">
      <a class="btn" href={wa} target="_blank" rel="noopener">{t.hero.b}</a>
      <a class="link" href={path("/contact", locale)}>{t.nav.contact}</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    min-height: 90svh;
    display: flex;
    align-items: center;
    padding-block: clamp(7rem, 16vh, 10rem) clamp(3rem, 8vh, 5rem);
    overflow: hidden;
  }
  .hero__content { position: relative; z-index: 1; }
  .hero .eyebrow { margin-bottom: clamp(1.5rem, 4vw, 2.5rem); }
  .hero__title {
    max-width: 18ch;
    white-space: pre-line; /* honor the deliberate line break in the hero */
    font-variation-settings: "opsz" 144, "SOFT" 70, "WONK" 1;
  }
  .hero__base {
    margin-top: clamp(2.5rem, 6vw, 5rem);
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 4vw, 3rem);
  }
  .hero__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 1.5rem 2rem;
    border-top: 1px solid var(--color-fog);
    padding-top: 1.5rem;
  }
  .hero__place {
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-stone);
  }
  .hero__cta {
    display: flex;
    align-items: center;
    gap: clamp(1.25rem, 4vw, 2.5rem);
  }

  /* .btn is global (see global.css) */

  .band { padding-block: var(--section-y); }
  .band--alt { background: var(--color-paper); }
  .band__grid {
    display: grid;
    grid-template-columns: minmax(0, 12rem) 1fr;
    gap: clamp(1.5rem, 5vw, 5rem);
  }
  .band__title { margin-bottom: 1.5rem; }
  .band__body { color: var(--color-ink-soft); }
  .band__more { margin-top: clamp(2rem, 4vw, 3rem); }
  @media (max-width: 48rem) {
    .band__grid { grid-template-columns: 1fr; gap: 1.25rem; }
  }

  .work { padding-block: var(--section-y); }
  .work__head { margin-bottom: clamp(2.5rem, 6vw, 4.5rem); }
  .work__title { margin-top: 1rem; max-width: 18ch; }
  .work__list { list-style: none; padding: 0; }
  .work__item { border-top: 1px solid var(--color-fog); }
  .work__item:last-child { border-bottom: 1px solid var(--color-fog); }
  .work__link {
    display: grid;
    grid-template-columns: minmax(0, 52%) 1fr;
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: center;
    padding-block: clamp(2.25rem, 5vw, 4rem);
  }
  .work__thumb {
    display: block;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    background: var(--color-paper);
    border: 1px solid var(--color-fog);
  }
  .work__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    filter: saturate(0.96);
    transform: scale(1.001);
    transition: transform 1.1s var(--ease), filter 0.9s var(--ease);
  }
  .work__link:hover .work__thumb img {
    transform: scale(1.04);
    filter: saturate(1.05);
  }
  .work__no {
    display: block;
    font-family: var(--font-display);
    font-size: 0.9rem;
    color: var(--color-stone);
    margin-bottom: 0.9rem;
  }
  .work__name {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-h2);
    line-height: 1.04;
  }
  .work__kind {
    display: block;
    margin-top: 0.75rem;
    font-size: 0.76rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-stone);
  }
  .work__line {
    display: block;
    margin-top: 1rem;
    max-width: 40ch;
    color: var(--color-ink-soft);
  }
  .work__view {
    display: inline-block;
    margin-top: 1.5rem;
    font-size: 0.76rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-stone);
  }
  .work__link:hover .work__view { color: var(--color-ink); }
  @media (max-width: 44rem) {
    .work__link { grid-template-columns: 1fr; gap: 1.25rem; }
  }

  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
  }

  /* What I build — restrained two-column list */
  .svc { padding-block: var(--section-y); }
  .svc__head { margin-bottom: clamp(2.5rem, 6vw, 4.5rem); max-width: 26ch; }
  .svc__title { margin-top: 1rem; }
  .svc__list {
    list-style: none;
    padding: 0;
    border-top: 1px solid var(--color-fog);
  }
  .svc__i {
    display: grid;
    grid-template-columns: minmax(0, 16rem) 1fr;
    gap: clamp(0.75rem, 4vw, 3rem);
    padding-block: clamp(1.5rem, 3.2vw, 2.4rem);
    border-bottom: 1px solid var(--color-fog);
  }
  .svc__n {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    line-height: 1.12;
  }
  .svc__o { max-width: 46ch; color: var(--color-ink-soft); }
  .svc__more {
    display: inline-block;
    margin-top: clamp(2rem, 4vw, 3rem);
    font-size: 0.8rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  @media (max-width: 40rem) {
    .svc__i { grid-template-columns: 1fr; gap: 0.5rem; }
  }

  /* How it works — numbered process */
  .proc { padding-block: var(--section-y); background: var(--color-paper); }
  .proc__head { margin-bottom: clamp(2.5rem, 6vw, 4.5rem); max-width: 24ch; }
  .proc__title { margin-top: 1rem; }
  .proc__list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(2rem, 5vw, 3.5rem) clamp(2rem, 6vw, 5rem);
  }
  .proc__s {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.25rem;
    align-items: start;
    border-top: 1px solid var(--color-fog);
    padding-top: 1.5rem;
  }
  .proc__k {
    font-family: var(--font-display);
    font-size: 0.95rem;
    color: var(--color-stone);
  }
  .proc__t {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    line-height: 1.1;
  }
  .proc__d {
    margin-top: 0.7rem;
    max-width: 38ch;
    color: var(--color-ink-soft);
  }
  @media (max-width: 44rem) {
    .proc__list { grid-template-columns: 1fr; }
  }

  /* Close — the real ending */
  .close {
    padding-block: clamp(6rem, 13vw, 11rem);
    border-top: 1px solid var(--color-fog);
  }
  .close .eyebrow { margin-bottom: clamp(1.5rem, 4vw, 2.5rem); }
  .close__t {
    max-width: 18ch;
    font-size: var(--text-h1);
    font-variation-settings: "opsz" 144, "SOFT" 70;
  }
  .close__b { margin-top: clamp(1.5rem, 3vw, 2.25rem); color: var(--color-ink-soft); }
  .close__cta { margin-top: clamp(2.5rem, 5vw, 3.5rem); gap: 1.25rem 2rem; }
</style>
