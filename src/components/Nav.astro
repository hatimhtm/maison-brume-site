---
import { content, type Locale, waLink } from "../lib/content";
import { path, other } from "../lib/paths";
import Mark from "./Mark.astro";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = content[locale];
const alt = other(locale);

// Anchored prefix strip — same page, other language. Regex-anchored so a
// path segment containing the base or starting with "fr…" can't be mangled.
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const here = Astro.url.pathname;
const altPath = (() => {
  let p = here;
  if (base && p.startsWith(base)) p = p.slice(base.length);
  p = p.replace(/^\/fr(?=\/|$)/, "");
  return path(p || "/", alt);
})();
const wa = waLink(locale);
---

<header class="nav">
  <div class="wrap nav__in">
    <a href={path("/", locale)} class="nav__brand" aria-label="Maison Brume — home">
      <Mark variant="monogram" />
    </a>
    <nav class="nav__links" aria-label="Primary">
      <a class="link" href={path("/work", locale)}>{t.nav.work}</a>
      <a class="link" href={path("/services", locale)}>{t.nav.services}</a>
      <a class="link" href={path("/studio", locale)}>{t.nav.studio}</a>
      <a class="nav__wa" href={wa} target="_blank" rel="noopener"
        >{t.contact.whatsapp}<span class="sr-only"> (opens WhatsApp)</span></a
      >
      <a
        class="nav__lang"
        href={altPath}
        hreflang={alt}
        lang={alt}
        aria-label={alt === "fr" ? "Voir en français" : "View in English"}
      >
        {alt === "fr" ? "FR" : "EN"}
      </a>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: absolute;
    inset: 0 0 auto 0;
    z-index: 50;
  }
  .nav__in {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem 1rem;
    padding-top: clamp(1.1rem, 2.4vw, 2rem);
    padding-bottom: 1rem;
  }
  .nav__brand {
    display: inline-flex;
    line-height: 1;
    padding-block: 0.4rem;
  }
  .nav__links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: clamp(0.85rem, 3vw, 2.4rem);
    font-size: 0.8rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
  }
  .nav__links a {
    display: inline-flex;
    align-items: center;
    min-height: 44px; /* WCAG 2.5.5 tap target */
  }
  .nav__wa {
    position: relative;
    color: var(--color-ink);
    font-weight: 500;
  }
  .nav__wa::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0.7rem;
    width: 100%;
    height: 1px;
    background: currentColor;
    transform: scaleX(1);
    transform-origin: left;
    transition: transform 0.5s var(--ease);
  }
  .nav__wa:hover::after {
    transform: scaleX(0);
    transform-origin: right;
  }
  .nav__lang {
    font-variant-numeric: tabular-nums;
    color: var(--color-stone);
    padding-left: clamp(0.4rem, 2vw, 1rem);
    border-left: 1px solid var(--color-fog);
  }
  .nav__lang:hover { color: var(--color-ink); }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }
  @media (max-width: 26rem) {
    .nav__links { gap: 0.8rem; font-size: 0.72rem; }
  }
</style>
